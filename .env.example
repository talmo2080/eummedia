# Supabase 프로젝트 연동 정보
# 이 파일은 placeholder입니다. 실제 값은 .env 파일에 따로 저장하세요.
# 실제 키는 Supabase 대시보드 → Settings → API 에서 복사하세요.
# https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 공공데이터포털 — 주식 시세 (GetStockSecuritiesInfoService)
# 발급: https://www.data.go.kr/data/15094808/openapi.do
# Vercel serverless(api/stocks.js)에서만 사용됨 (CORS 회피)
# 값은 .env 파일에 입력. Vercel 환경변수에도 동일 등록 필요.
VITE_STOCK_API_KEY=your-data-go-kr-key-here
